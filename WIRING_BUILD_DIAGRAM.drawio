        </mxCell>
        <mxCell id="build-note3-detail" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" value="   a) Wire PSU to switch&#xa;   b) Wire switch to PCB rails&#xa;   c) Wire PSU GND to PCB GND rail&#xa;   d) Connect all components to rails&#xa;   e) Wire data/control signals last" vertex="1">
          <mxGeometry height="75" width="240" x="120" y="590" as="geometry" />
        </mxCell>
