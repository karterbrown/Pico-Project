        </mxCell>
        <mxCell id="build-note2-detail" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" value="   Install between PSU +5V and PCB&#xa;   NO ground connection needed&#xa;   Switch breaks +5V line only" vertex="1">
